<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiPractica.Pages.EmpleadosPage"
             Title="EmpleadosPage">
    <VerticalStackLayout>
        <CollectionView SelectionMode="Single" SelectionChanged="OnEmpleadoSeleccionado" ItemsSource="{Binding Empleados}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="Gray" StrokeThickness="1" Padding="10" Margin="0,0,0,10" BackgroundColor="#222">
                        <VerticalStackLayout>
                            <Label Text="{Binding Nombre}" FontSize="18" TextColor="White"/>
                            <Label Text="{Binding Apellido}" FontSize="14" TextColor="LightGray"/>
                            <Label Text="{Binding Puesto}" FontSize="14" TextColor="LightGray"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>