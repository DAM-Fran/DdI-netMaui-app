<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiPractica.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:MauiPractica.Pages"
    
    Title="MauiPractica">

    <TabBar>
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate pages:MainPage}"
            Route="main"
            />

        <ShellContent
            Title="Empleados"
            ContentTemplate="{DataTemplate pages:EmpleadosPage}"
            Route="empleados"
            />

        <ShellContent
            Title="Departamentos"
            ContentTemplate="{DataTemplate pages:DepartamentosPage}"
            Route="departamentos"
            />
    </TabBar>
</Shell>